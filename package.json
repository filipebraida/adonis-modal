{
  "name": "adonis-inertia-modal",
  "description": "Backend-driven modals for Inertia.js on AdonisJS",
  "version": "0.1.0-alpha.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests",
    "styles.css"
  ],
  "main": "build/index.js",
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/src/types.js",
    "./modal_provider": "./build/providers/modal_provider.js",
    "./react": "./build/src/client/react/index.js",
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "precompile": "npm run lint",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "npm run compile",
    "release": "release-it",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "adonisjs",
    "inertia",
    "inertiajs",
    "modal",
    "slideover"
  ],
  "author": "Filipe Braida",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipebraida/adonis-inertia-modal.git"
  },
  "homepage": "https://github.com/filipebraida/adonis-inertia-modal#readme",
  "bugs": {
    "url": "https://github.com/filipebraida/adonis-inertia-modal/issues"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "@happy-dom/global-registrator": "^16.8.1",
    "@inertiajs/core": "^2.3.26",
    "@inertiajs/react": "^2.3.26",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@release-it/conventional-changelog": "^10.0.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "edge.js": "^6.2.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/inertia": "^4.0.0 || ^5.0.0-next.0",
    "@inertiajs/react": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    },
    "@inertiajs/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "tsdown": {
    "entry": [
      "./index.ts",
      "./configure.ts",
      "./stubs/main.ts",
      "./src/types.ts",
      "./providers/modal_provider.ts",
      "./src/client/react/index.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "minify": "dce-only",
    "fixedExtension": false,
    "dts": false,
    "treeshake": false,
    "sourcemaps": false,
    "target": "esnext"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
